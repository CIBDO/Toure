# CANAM Contract Manager — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs (ne pas committer .env).

APP_NAME="CANAM Contract Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://votre-domaine.ml

APP_TIMEZONE=UTC
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
APP_PREVIOUS_KEYS=

# Base de données (prod : mysql ou pgsql)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=canam_db
DB_USERNAME=canam_user
DB_PASSWORD=

# Pour PostgreSQL :
# DB_CONNECTION=pgsql
# DB_PORT=5432

# Cache & sessions (optionnel)
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=

# Logs (prod : error ou warning)
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_STACK=single
LOG_DAILY_DAYS=14

# File d'attente (optionnel)
QUEUE_CONNECTION=database

# Mail (optionnel)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@canam.ml"
MAIL_FROM_NAME="${APP_NAME}"

# GED — taille max fichier (Mo)
GED_MAX_FILE_SIZE_MB=20

# Frontend — à définir au moment du build (npm run build)
# URL de base de l'API (sans slash final)
VITE_API_BASE_URL=https://votre-domaine.ml/api

# Lien dans les emails (ex. réinitialisation mot de passe). Par défaut = APP_URL.
# En local avec "php artisan serve" : mettre http://127.0.0.1:8000 si besoin.
# FRONTEND_URL=https://votre-domaine.ml

# Données de démo : mettre à true uniquement en dev/staging pour charger DemoDataSeeder
APP_SEED_DEMO=false

# Redis (optionnel)
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=
# REDIS_PORT=6379

# AWS / stockage (optionnel)
# FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_URL=
